# Hugging Face (for model downloads)
HF_TOKEN=your_huggingface_token_here

# AWS credentials (for S3 access)
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-guardrail-bucket-name

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# RAG data paths (override defaults if using a custom S3 bucket)
RAG_DATASET_PATH=s3://your-guardrail-bucket-name/processed/train.parquet
WIKI_RAG_DATASET_PATH=s3://your-guardrail-bucket-name/knowledge_base/wikipedia/simplewiki_articles.parquet

# Supabase (frontend database)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
